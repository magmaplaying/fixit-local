// FixIt Local — hyperlocal services marketplace
// SQLite for dev (no native enums / no scalar lists → String fields + JSON text).
// Allowed string values are documented inline and enforced in app code (Zod/TS unions).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("CUSTOMER") // CUSTOMER | PROVIDER | ADMIN
  status       String   @default("ACTIVE") // ACTIVE | SUSPENDED
  emailNotifications Boolean @default(true) // opt-out of transactional emails
  referralCode String?  @unique // this user's own shareable invite code
  referredById String? // the user who invited them (attribution)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  provider ProviderProfile?
  bookings Booking[]        @relation("CustomerBookings")
  reviews  Review[]
  messages Message[]
  reports  Report[]
  notifications Notification[]
  referredBy   User?  @relation("Referrals", fields: [referredById], references: [id])
  referrals    User[] @relation("Referrals")
}

model ProviderProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio       String?
  phone     String?
  city      String
  area      String?
  avatarUrl String?
  verified  Boolean  @default(false)
  ratingAvg   Float?
  ratingCount Int      @default(0)
  stripeAccountId String?
  payoutsEnabled  Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  listings Listing[]
}

model Category {
  id   String  @id @default(cuid())
  name String
  slug String  @unique
  icon String?

  listings Listing[]
}

model Listing {
  id          String          @id @default(cuid())
  providerId  String
  provider    ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category        @relation(fields: [categoryId], references: [id])
  title       String
  description String
  priceType   String          @default("HOURLY") // HOURLY | FIXED | QUOTE
  price       Float?
  city        String
  area        String?
  photos      String          @default("[]") // JSON-encoded array of image URLs
  active      Boolean         @default(true)
  featuredUntil DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @default(now()) @updatedAt

  bookings Booking[]
  reviews  Review[]

  @@index([categoryId])
  @@index([city])
  @@index([city, categoryId])
}

model Booking {
  id           String    @id @default(cuid())
  listingId    String
  listing      Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  customerId   String
  customer     User      @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: Cascade)
  status       String    @default("REQUESTED") // REQUESTED | ACCEPTED | DECLINED | COMPLETED | CANCELLED
  scheduledFor DateTime?
  message      String?
  amount       Float? // charge amount (set at acceptance; payments groundwork)
  currency     String    @default("BGN") // BGN today; EUR transition ahead
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt
  customerReadAt DateTime?
  providerReadAt DateTime?

  review   Review?
  payment  Payment?
  messages Message[]

  @@index([listingId])
  @@index([customerId])
}

model Review {
  id        String   @id @default(cuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  rating    Int // 1-5
  comment   String?
  hidden    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([listingId])
}

model Message {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())

  @@index([bookingId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // BOOKING_REQUESTED | BOOKING_ACCEPTED | BOOKING_DECLINED | BOOKING_COMPLETED | BOOKING_CANCELLED | NEW_MESSAGE | PAYMENT_RECEIVED
  title     String
  body      String
  href      String? // app-relative link the notification points at
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Report {
  id         String   @id @default(cuid())
  reporterId String
  reporter   User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  targetType String // LISTING | REVIEW | USER
  targetId   String
  reason     String
  status     String   @default("OPEN") // OPEN | RESOLVED | DISMISSED
  createdAt  DateTime @default(now())

  @@index([status])
}

model Payment {
  id                    String   @id @default(cuid())
  bookingId             String   @unique
  booking               Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  stripePaymentIntentId String?  @unique
  amount                Int // minor units (stotinki/cents)
  currency              String   @default("BGN")
  commissionAmount      Int      @default(0) // minor units, platform fee
  status                String   @default("PENDING") // PENDING | REQUIRES_ACTION | SUCCEEDED | REFUNDED | FAILED
  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now()) @updatedAt
}

# Copy this file to `.env` and fill in the values.

# --- Database ---
# Local development: a SQLite file (no token needed).
DATABASE_URL="file:./dev.db"
# Production (Turso): set DATABASE_URL to your libsql://... URL and provide a token.
# TURSO_AUTH_TOKEN=""

# --- Auth ---
# Secret used to sign session JWTs. MUST be a strong random value in production.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="change-me-in-production"
